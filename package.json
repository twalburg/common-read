{
  "name": "common-read",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist",
    "db:create": "wrangler d1 create common-read-db",
    "db:migrate": "wrangler d1 execute common-read-db --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute common-read-db --local --file=./schema.sql"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240512.0",
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^5.2.0",
    "wrangler": "^3.57.0"
  }
}
